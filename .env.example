# ── Required ──────────────────────────────────────────────────────────────────
# Get your key from https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-proj-your-key-here

# ── Optional overrides (defaults shown) ──────────────────────────────────────
# LLM model — gpt-4o-mini (default), gpt-4o (higher quality), gpt-4-turbo
MODEL_NAME=gpt-4o-mini

# Embedding model — text-embedding-3-large (default), text-embedding-3-small (cheaper)
EMBED_MODEL=text-embedding-3-large

# Chunk size in tokens (default: 1000)
CHUNK_SIZE=1000

# Number of chunks to retrieve per query (default: 8)
TOP_K_RETRIEVAL=8

# Vector store path (default: vectorstore/faiss_index)
VECTOR_DB_PATH=vectorstore/faiss_index
